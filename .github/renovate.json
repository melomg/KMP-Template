{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "branchPrefix": "renovate/",
  "prConcurrentLimit": 2,
  "prHourlyLimit": 1,
  "packageRules": [
    {
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true,
      "description": "Schedule every weekend",
      "schedule": [
        "* * * * 0,6"
      ]
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "automergeStrategy": "rebase",
      "description": "Schedule every weekend",
      "schedule": [
        "* * * * 0,6"
      ]
    }
  ],
  "semanticCommits": "enabled",
  "timezone": "Europe/Amsterdam"
}
